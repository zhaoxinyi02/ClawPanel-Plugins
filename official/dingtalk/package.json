{
  "name": "dingtalk",
  "version": "0.2.0",
  "description": "DingTalk (钉钉) channel plugin for Clawdbot - enables AI agent messaging via DingTalk Stream API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "clawdbot": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "clawdbot",
    "clawdbot-plugin",
    "dingtalk",
    "钉钉",
    "chatbot",
    "ai-agent",
    "enterprise-messaging"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "ws": "^8.18.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "clawdbot": "*",
    "openclaw": "*"
  }
}
